# Host application should provide model and sandbox settings.
RESEARCH_AGENT_WORKSPACE_ROOT=.
RESEARCH_AGENT_RUNS_DIR=runs
RESEARCH_AGENT_SKILLS_DIR=skills
RESEARCH_AGENT_MEMORY_DIR=memory

# Corporate default: do not expose internet/browser/raw shell tools.
RESEARCH_AGENT_ALLOW_INTERNET_TOOLS=false
RESEARCH_AGENT_ALLOW_RAW_SHELL=false
