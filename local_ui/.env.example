# OpenAI-совместимый провайдер. Значения ниже являются примерами и не содержат ключей.
OPENAI_API_KEY=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
OPENAI_BASE_URL=https://openrouter.ai/api/v1
DEEP_AGENT_MODEL=z-ai/glm-5

DEEP_AGENT_TEMPERATURE=0.1
DEEP_AGENT_TIMEOUT=120
DEEP_AGENT_MAX_RETRIES=0

# Отключить token-streaming у провайдера (рекомендуется, если API не поддерживает stream).
# UI всё равно получает обновления графа: tool calls, todos, финальные сообщения.
DEEP_AGENT_DISABLE_STREAMING=true

# LangSmith не требуется для локального UI.
LANGSMITH_TRACING=false

