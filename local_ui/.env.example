# Пример настроек OpenAI-compatible провайдера.
DEEP_AGENT_MODEL_PROVIDER=openai
DEEP_AGENT_MODEL=deepseek/deepseek-v4-flash
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://provider.example/v1

DEEP_AGENT_TEMPERATURE=0.1
DEEP_AGENT_TIMEOUT=120
DEEP_AGENT_MAX_RETRIES=0

# Для KitAI переключите провайдер и задайте корпоративные пути:
# DEEP_AGENT_MODEL_PROVIDER=kitai
# DEEP_AGENT_MODEL=GigaChat-2-Max
# KITAI_HOST_SDK=https://kitai.example.internal
# KITAI_CERT_FILE_PATH=/path/to/client.crt
# KITAI_CERT_KEY_FILE_PATH=/path/to/client.key
# KITAI_SYSTEM_NAME=lab
# KITAI_MODULE_NAME=lab_antifraud_edge
# KITAI_VERIFY_SSL=false
# KITAI_POLLING_RETRIES=500
# KITAI_POLLING_DELAY_SECONDS=2
# KITAI_POLLING_START_DELAY_SECONDS=2
# KITAI_POLLING_TIMEOUT_SECONDS=180
# KITAI_PROFANITY_CHECK=false
# KITAI_VERBOSE=true
